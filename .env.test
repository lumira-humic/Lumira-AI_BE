# App
NODE_ENV=test
PORT=3001
APP_NAME=Lumira AI API (Test)
CORS_ORIGINS=*

# Database
DB_HOST=localhost
DB_PORT=5433
DB_USERNAME=postgres
DB_PASSWORD=secret
DB_NAME=lumira_ai_db_test
